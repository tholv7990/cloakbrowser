# Copy to `.env.local` for local development.

# Which API implementation to use: "mock" (in-browser fixtures) or "real" (live backend).
VITE_API_MODE=real

# Base URL of the FastAPI backend, including the /api/v1 prefix.
# The backend binds to loopback only; the port is assigned per install.
VITE_API_BASE_URL=/api/v1

# WebSocket endpoint for runtime events. If unset it is derived from
# VITE_API_BASE_URL (http->ws) + "/events".
# VITE_WS_URL=ws://127.0.0.1:8799/api/v1/events

# Auth uses an HttpOnly session cookie + a CSRF token from GET /auth/session.
# There is no frontend token env var — the session token never reaches JS.

# Optional: background image for the login hero. Point at a file in public/
# (e.g. /auth-bg.jpg) or any URL. Unset = the original CloakBrowser SVG hero.
# VITE_AUTH_BG_URL=/auth-bg.jpg
